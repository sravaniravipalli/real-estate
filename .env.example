# Firebase Configuration
VITE_REACT_APP_API_KEY=your_firebase_api_key_here
VITE_REACT_APP_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_REACT_APP_PROJECT_ID=your_project_id
VITE_REACT_APP_STORAGE_BUCKET=your_project_id.appspot.com
VITE_REACT_APP_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_REACT_APP_APP_ID=your_app_id

# API Configuration
VITE_REACT_API_URL=http://localhost:5000

# Mailchimp Configuration
VITE_REACT_APP_PUBLIC_MAILCHIMP_URL=your_mailchimp_subscription_url_here

# Notes:
# 1. Copy this file to .env and replace the placeholder values
# 2. Never commit .env file to version control
# 3. Get Firebase credentials from Firebase Console
# 4. Get Mailchimp URL from Mailchimp embedded form
